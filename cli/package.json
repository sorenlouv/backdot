{
  "name": "backdot",
  "version": "1.8.3",
  "description": "Lightweight CLI to backup dotfiles and gitignored files to a Git repo on a daily schedule",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sorenlouv/backdot.git"
  },
  "main": "dist/cli.js",
  "bin": {
    "backdot": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "dotfiles",
    "backup",
    "git",
    "cli",
    "launchd",
    "gitignore"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "fmt": "prettier --write src/",
    "fmt:check": "prettier --check src/",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prepare": "cd .. && husky",
    "start": "node dist/cli.js",
    "test": "vitest run --exclude src/e2e.test.ts --exclude src/git.integration.test.ts",
    "test:all": "npm run build && vitest run",
    "test:e2e": "npm run build && vitest run src/e2e.test.ts",
    "test:integration": "vitest run src/git.integration.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "cac": "^7.0.0",
    "chalk": "^5.6.2",
    "fast-glob": "^3.3.3",
    "ora": "^9.4.0",
    "p-retry": "^8.0.0",
    "simple-git": "^3.36.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
